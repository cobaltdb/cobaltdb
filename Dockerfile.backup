# CobaltDB Backup Service Dockerfile
FROM golang:1.24-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git make

# Set working directory
WORKDIR /build

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build CLI binary for backup operations
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o /build/cobaltdb-cli \
    ./cmd/cobaltdb-cli

# Build migration tool
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o /build/cobaltdb-migrate \
    ./cmd/cobaltdb-migrate

# Runtime stage
FROM alpine:latest

# Install runtime dependencies including dos2unix for line ending conversion
RUN apk add --no-cache ca-certificates tzdata bash dos2unix

# Create backup user
RUN addgroup -g 1000 -S cobaltdb && \
    adduser -u 1000 -S cobaltdb -G cobaltdb

# Create directories
RUN mkdir -p /backups /data/source /scripts && \
    chown -R cobaltdb:cobaltdb /backups

# Copy binaries from builder
COPY --from=builder /build/cobaltdb-cli /usr/local/bin/
COPY --from=builder /build/cobaltdb-migrate /usr/local/bin/

# Create backup script - using printf to avoid line ending issues
RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -e' \
    '' \
    '# Configuration' \
    'BACKUP_DIR="/backups"' \
    'SOURCE_DIR="/data/source"' \
    'RETENTION_DAYS="${BACKUP_RETENTION_DAYS:-7}"' \
    'TIMESTAMP=$(date +%Y%m%d_%H%M%S)' \
    '' \
    'echo "========================================"' \
    'echo "CobaltDB Backup - $(date)"' \
    'echo "========================================"' \
    '' \
    '# Create backup directory' \
    'mkdir -p "${BACKUP_DIR}"' \
    '' \
    '# Create file-level backup (copy database files)' \
    'if [ -d "${SOURCE_DIR}" ] && [ "$(ls -A ${SOURCE_DIR} 2>/dev/null)" ]; then' \
    '    BACKUP_FILE="${BACKUP_DIR}/cobaltdb_backup_${TIMESTAMP}.tar.gz"' \
    '    echo "Creating backup: ${BACKUP_FILE}"' \
    '    tar czf "${BACKUP_FILE}" -C "${SOURCE_DIR}" . 2>/dev/null || {' \
    '        echo "Warning: Some files may have been skipped (busy/locked)"' \
    '    }' \
    '' \
    '    # Verify backup was created' \
    '    if [ -f "${BACKUP_FILE}" ]; then' \
    '        SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)' \
    '        echo "Backup created successfully: ${SIZE}"' \
    '    else' \
    '        echo "ERROR: Backup file was not created"' \
    '        exit 1' \
    '    fi' \
    'else' \
    '    echo "Warning: Source directory is empty or does not exist"' \
    '    echo "Source: ${SOURCE_DIR}"' \
    'fi' \
    '' \
    '# Clean up old backups (older than retention period)' \
    'echo "Cleaning up backups older than ${RETENTION_DAYS} days..."' \
    'DELETED=$(find "${BACKUP_DIR}" -name "cobaltdb_backup_*.tar.gz" -mtime +${RETENTION_DAYS} -print 2>/dev/null | wc -l)' \
    'find "${BACKUP_DIR}" -name "cobaltdb_backup_*.tar.gz" -mtime +${RETENTION_DAYS} -delete 2>/dev/null || true' \
    'echo "Cleaned up ${DELETED} old backup(s)"' \
    '' \
    'echo "Backup completed at $(date)"' \
    'echo "Current backups:"' \
    'ls -lh "${BACKUP_DIR}"/*.tar.gz 2>/dev/null || echo "  No backups found"' \
    > /scripts/backup.sh

# Create entrypoint script (using simple loop instead of cron for non-root)
RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -e' \
    '' \
    'SCHEDULE="${BACKUP_SCHEDULE:-0 2 * * *}"' \
    'INTERVAL_HOURS="${BACKUP_INTERVAL_HOURS:-24}"' \
    '' \
    'echo "CobaltDB Backup Service"' \
    'echo "======================="' \
    'echo "Schedule: ${SCHEDULE}"' \
    'echo "Interval: ${INTERVAL_HOURS} hours"' \
    'echo "Retention: ${BACKUP_RETENTION_DAYS} days"' \
    'echo "Backup Dir: /backups"' \
    'echo "Source Dir: /data/source"' \
    'echo ""' \
    '' \
    '# Run initial backup on startup' \
    'echo "Running initial backup..."' \
    '/scripts/backup.sh' \
    '' \
    '# Keep running with scheduled backups' \
    'if [ -n "${SCHEDULE}" ]; then' \
    '    echo ""' \
    '    echo "Starting backup scheduler (runs every ${INTERVAL_HOURS} hours)..."' \
    '    echo "Recent backups:"' \
    '    ls -lh /backups/*.tar.gz 2>/dev/null | tail -5 || echo "  No backups yet"' \
    '    echo ""' \
    '    while true; do' \
    '        sleep ${INTERVAL_HOURS}h' \
    '        echo ""' \
    '        echo "Running scheduled backup at $(date)..."' \
    '        /scripts/backup.sh' \
    '    done' \
    'else' \
    '    echo "No schedule set. Running in one-shot mode."' \
    '    exit 0' \
    'fi' \
    > /scripts/entrypoint.sh

# Convert line endings and make scripts executable
RUN dos2unix /scripts/backup.sh /scripts/entrypoint.sh && \
    chmod +x /scripts/backup.sh /scripts/entrypoint.sh && \
    chown -R cobaltdb:cobaltdb /scripts /backups /data/source


# Switch to non-root user
USER cobaltdb

# Volume for backups
VOLUME ["/backups"]

# Health check - check for recent backup
HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
    CMD ls /backups/*.tar.gz 1>/dev/null 2>&1 && echo "OK" || exit 1

# Entrypoint
ENTRYPOINT ["/scripts/entrypoint.sh"]
